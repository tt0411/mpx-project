      </view>
    </view>
  </view>
  <view class="flex items-center justify-evenly py-20rpx bg-#fff">
    <view wx:for="{{menuList}}" wx:key="index" class="flex-col-center"> 
      <text wx:class="{{'text-40rpx text-center text-#333 iconfont ' + item.icon}}"></text>
      <view class="text-#333 text-28rpx mt-8rpx">{{item.label}}</view>
