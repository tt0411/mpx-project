  <mpx-custom-nav-ali title="我的" @ali />
  <view class="gradient-primary-bg pl-20rpx py-20rpx flex items-center justify-between">
    <view class="bg-#fff rounded-50% w-100rpx h-100rpx flex-center mr-20rpx">
        <van-image width="40" height="40" src="{{pictureUrl}}" mode="aspectFill" />
    </view>
    <view class="flex-1 flex-col items-center justify-around text-28rpx text-#333">
      <view class="mb-10rpx">{{workerInfo.workerName}}</view>
      <view class="mb-10rpx">{{workerInfo.phone}}</view>
      <view>{{workerInfo.outletsCodes_t}}</view>
    </view>
    <view class="flex-col items-center justify-around">
      <view class="flex-center bg-#fbe1b3 rounded-l-24rpx pl-5rpx">
