<script>
  import mpx, { createPage } from '@mpxjs/core'
  import { useCommonStore } from '@/store'
  import { mapActions } from '@mpxjs/pinia'

  createPage({
    data: {
      workerInfo: {
        workerName: '测试师傅',
        phone: '13912345678',
        outletsCodes_t: '滨江服务站',
      },
      menuList: [
        { label: '提现账户', icon: 'icon-qianbao1', path: '' },
        { label: '商城订单', icon: 'icon-jifenshangcheng', path: '' },
        { label: '完工工单', icon: 'icon-wancheng', path: '' },
        { label: '对账单', icon: 'icon-tixian', path: '' },
        { label: '资料', icon: 'icon-zerenren', path: '' },
      ],
      pictureUrl: 'https://cbs-worker-wxapp.oss-cn-hangzhou.aliyuncs.com/prod/E.png'
    },
    computed: {
  
    },
    methods: {
      ...mapActions(useCommonStore, ['setActiveTabbarIndex']),
      logout() {
        mpx.showModal({
          title: '提示',
          content: '确定退出登录吗？',
          success: (res) => {
            if (res.confirm) {
              this.setActiveTabbarIndex(0)
              mpx.removeStorageSync('cookies')
              mpx.reLaunch({
                url: '/pagesMine/login/index'
              })
            }
          }
        })
      },
      goMap() {
        mpx.navigateTo({
          url: '/pagesCommon/map/index'
        })
      },
      changeImg() {

      }
    }
  })
</script>

<script name="json">
  const obj =
    __mpx_mode__ === 'ali'
      ? {
          transparentTitle: 'always',
          titlePenetrate: 'YES',
          defaultTitle: '',
          titleBarColor: '#000000',
          disabledScroll: true
        }
      : {
          navigationBarTitleText: '我的',
          disabledScroll: true,
          navigationStyle: 'custom'
        }
  module.exports = {
    usingComponents: {
      'more-function': './components/more-function.mpx'
    },
