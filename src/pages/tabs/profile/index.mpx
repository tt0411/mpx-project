.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.login-button {
  margin-top: 24rpx;
  background: #FF2442;
  color: #fff;
  border-radius: 999rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  margin-right: 20rpx;
  border-radius: 999rpx;
}

.profile-main {
  flex: 1;
}

.profile-name,
.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.edit-link,
.section-link {
  font-size: 24rpx;
  color: #FF2442;
}

.stats-card {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.action-row {
  display: flex;
  margin-top: 20rpx;
}

.action-card {
  flex: 1;
  padding: 24rpx;
}

.action-card-left {
  margin-right: 16rpx;
}

.section-block {
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.feed-grid {
  display: flex;
  gap: 16rpx;
}

.feed-column {
  flex: 1;
}

.menu-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.menu-card.danger {
  border-top: 1px solid #f2f2f2;
}

.menu-title {
  font-size: 28rpx;
  color: #222;
}

.menu-arrow {
  font-size: 24rpx;
  color: #999;
}

.menu-title.danger,
.menu-arrow.danger {
  color: #FF2442;
}
</style>
