<template>
  <view class="page profile-page">
    <view wx:if="{{ !isLogin }}" class="login-card">
      <view class="login-title">登录后查看你的内容资产</view>
      <view class="login-desc">我的发布、草稿箱、收藏预览和互动数据都会集中展示在这里。</view>
      <button class="login-button" bindtap="goLogin">去登录</button>
    </view>

    <view wx:else>
      <view class="profile-header">
        <image class="profile-avatar" src="{{ myProfile.avatar }}" mode="aspectFill" />
        <view class="profile-main">
          <view class="profile-name">{{ myProfile.nickname }}</view>
          <view class="profile-bio">{{ myProfile.bio || '开始写下你的第一条生活笔记。' }}</view>
        </view>
        <view class="edit-link" bindtap="goEditProfile">编辑</view>
      </view>

      <view class="stats-card">
        <view class="stat-item">
          <view class="stat-value">{{ myStats.followCount }}</view>
          <view class="stat-label">关注</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{ myStats.fansCount }}</view>
          <view class="stat-label">粉丝</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{ myStats.likedReceivedCount }}</view>
          <view class="stat-label">获赞</view>
        </view>
      </view>

      <view class="action-row">
        <view class="action-card action-card-left" bindtap="goMyNotes">
          <view class="action-title">我的发布</view>
          <view class="action-desc">{{ myNotes.list.length }} 篇内容</view>
        </view>
        <view class="action-card" bindtap="goDraftList">
          <view class="action-title">草稿箱</view>
          <view class="action-desc">{{ draftSummary.count }} 篇未发布</view>
        </view>
      </view>

      <view class="section-block">
        <view class="section-header">
          <view class="section-title">我的笔记</view>
          <view class="section-link" bindtap="goMyNotes">查看全部</view>
        </view>
        <mpx-empty wx:if="{{ !myNotes.loading && myNotes.list.length === 0 }}" title="还没有发布内容" desc="发布成功后会显示在这里。" />
        <view wx:else class="feed-grid">
          <view class="feed-column">
            <note-card wx:for="{{ leftColumn }}" wx:key="id" note="{{ item }}" bind:cardtap="handleCardTap" bind:authortap="noop" />
          </view>
          <view class="feed-column">
            <note-card wx:for="{{ rightColumn }}" wx:key="id" note="{{ item }}" bind:cardtap="handleCardTap" bind:authortap="noop" />
          </view>
        </view>
      </view>

      <view class="section-block">
        <view class="section-header">
          <view class="section-title">功能入口</view>
        </view>
        <view class="menu-card" bindtap="goSettings">
          <view class="menu-title">设置</view>
          <view class="menu-arrow">></view>
        </view>
        <view class="menu-card danger" bindtap="logout">
          <view class="menu-title danger">退出登录</view>
          <view class="menu-arrow danger">></view>
        </view>
      </view>
    </view>
  </view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import { mapActions, mapState } from '@mpxjs/pinia'
import { useProfileStore, useUserStore } from '@/store'
import { navigateTo, reLaunch } from '@/utils'

function splitColumns(list = []) {
  return list.slice(0, 4).reduce((columns, item, index) => {
    columns[index % 2].push(item)
    return columns
  }, [[], []])
}

createPage({
  computed: {
    ...mapState(useUserStore, ['isLogin']),
    ...mapState(useProfileStore, ['myProfile', 'myStats', 'myNotes', 'draftSummary']),
    leftColumn() {
      return splitColumns(this.myNotes.list || [])[0]
    },
    rightColumn() {
      return splitColumns(this.myNotes.list || [])[1]
    }
  },
  async onShow() {
    if (!this.isLogin) return
    await Promise.all([
      this.fetchMyProfile(),
      this.fetchMyNotes({ refresh: true }),
      this.fetchDraftSummary()
    ])
  },
  methods: {
    ...mapActions(useUserStore, ['clearSession']),
    ...mapActions(useProfileStore, ['fetchMyProfile', 'fetchMyNotes', 'fetchDraftSummary']),
    goLogin() {
      navigateTo('login')
    },
    goEditProfile() {
      navigateTo('edit-profile')
    },
    goMyNotes() {
      navigateTo('my-notes')
    },
    goDraftList() {
      navigateTo('draft-list')
    },
    goSettings() {
      navigateTo('settings')
    },
    handleCardTap(e) {
      navigateTo('note-detail', { noteId: e.detail.note.id })
    },
    noop() {},
    logout() {
      this.clearSession()
      reLaunch('home')
    }
  }
})
</script>

<script name="json">
module.exports = {
  navigationBarTitleText: '我的',
  allowsBounceVertical: 'NO',
  usingComponents: {
    'note-card': '@/components/note-card'
  }
}
</script>

