    font-weight: 600;
    color: #000;
    font-size: 30rpx;
    margin-right: 10rpx;
  }

  .gap-line {
    width: 1rpx;
    height: 30rpx;
    border-left: 1rpx solid #e3e4e6;
    margin: 0 20rpx;
  }

  .icon {
    border-radius: 50%;
    color: #fff;
    background-color: $primary-color;
    padding: 10rpx;
  }

  .icon-dingwei2 {
    color: #508ed6;
    font-size: 40rpx;
    padding-left: 20rpx;
    margin-right: 20rpx;
  }
}

.info-box {
  padding: 0 30rpx 10rpx 30rpx;
  display: flex;

  .iconfont {
    font-size: 34rpx;
  }

  .icon-shebeiguanli {
    color: #333;
  }

  .label {
    color: #333;
    font-size: 28rpx;
    margin-left: 20rpx;
    word-break: break-all;
    margin-right: 20rpx;
  }
}

.skeleton-customer-info {
  padding: 20rpx 30rpx;
  margin: 0 20rpx 20rpx 20rpx;
  background-color: #f7f8fa;
  border-radius: 20rpx;
}

.skeleton-info-box {
  padding: 10rpx 30rpx;
  display: flex;
  align-items: center;
}

.skeleton-item {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-animation 1.4s ease infinite;
}

@keyframes skeleton-animation {
  0% {
    background-position: 100% 50%;
  }

  100% {
    background-position: 0 50%;
  }
}
</style>
